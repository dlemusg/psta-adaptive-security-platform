        <mxCell id="e14" edge="1" source="decision" target="rollback" parent="1" value="No" style="endArrow=block;html=1;strokeColor=#b85450;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e15" edge="1" source="decision" target="prod100" parent="1" value="Sí" style="endArrow=block;html=1;strokeColor=#82b366;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e16" edge="1" source="flags" target="canary5" parent="1" value="Habilita funcionalidad" style="dashed=1;endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e17" edge="1" source="rollback" target="stable" parent="1" value="Restaurar versión estable" style="endArrow=block;html=1;strokeColor=#b85450;">
