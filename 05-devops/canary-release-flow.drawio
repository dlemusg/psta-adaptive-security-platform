        <mxCell id="e6" edge="1" source="stable" target="canary5" parent="1" value="95% tráfico" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" source="canary5" target="canary25" parent="1" value="OK" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
