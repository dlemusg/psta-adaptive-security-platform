        <mxCell id="e10" edge="1" source="canary5" target="metrics" parent="1" style="dashed=1;endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e11" edge="1" source="canary25" target="metrics" parent="1" style="dashed=1;endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
