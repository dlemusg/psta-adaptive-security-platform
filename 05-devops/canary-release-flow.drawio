        </mxCell>

        <mxCell id="e4" edge="1" source="azure-cd" target="eks" parent="1" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" source="eks" target="canary5" parent="1" value="Deploy v2" style="endArrow=block;html=1;">
