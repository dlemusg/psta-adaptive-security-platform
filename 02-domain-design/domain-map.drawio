<mxfile host="app.diagrams.net">
  <diagram name="Domain Map">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="1" pageScale="1"
                  pageWidth="1800" pageHeight="1200">

      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Título -->

        <mxCell id="title"
                value="PSTA - Domain Map"
                style="text;html=1;fontSize=24;fontStyle=1;strokeColor=none;fillColor=none;"
                vertex="1"
                parent="1">
          <mxGeometry x="700" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- CORE DOMAINS -->

        <mxCell id="core1"
                value="CORE DOMAIN&#10;Decisión Transaccional"
                style="swimlane;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="650" y="150" width="300" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="core2"
                value="CORE DOMAIN&#10;Monitoreo de Riesgo y Fraude"
                style="swimlane;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="250" y="420" width="320" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="core3"
                value="CORE DOMAIN&#10;Autenticación Adaptativa"
                style="swimlane;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="1030" y="420" width="320" height="140" as="geometry"/>
        </mxCell>

        <!-- SUPPORTING DOMAINS -->

        <mxCell id="support1"
                value="SUPPORTING DOMAIN&#10;Gestión de Dispositivos"
                style="swimlane;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="40" y="760" width="260" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="support2"
                value="SUPPORTING DOMAIN&#10;Perfil de Cliente"
                style="swimlane;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="360" y="760" width="260" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="support3"
                value="SUPPORTING DOMAIN&#10;Protección de Cuenta"
                style="swimlane;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="680" y="760" width="260" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="support4"
                value="SUPPORTING DOMAIN&#10;Proveedores de Factores"
                style="swimlane;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="1000" y="760" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- GENERIC DOMAIN -->

        <mxCell id="generic"
                value="GENERIC DOMAIN&#10;Auditoría y Evidencia"
                style="swimlane;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="1340" y="760" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- EVENT PLATFORM -->

        <mxCell id="platform"
                value="Kafka Event Backbone&#10;Integración Asíncrona&#10;Event Driven Architecture"
                style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="610" y="980" width="450" height="90" as="geometry"/>
        </mxCell>

        <!-- RELACIONES PRINCIPALES -->

        <mxCell id="e1"
                edge="1"
                source="core1"
                target="core2"
                parent="1"
                value="Solicita evaluación de riesgo"
                style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2"
                edge="1"
                source="core1"
                target="core3"
                parent="1"
                value="Solicita autenticación"
                style="endArrow=block;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- RISK -->

        <mxCell id="e3"
                edge="1"
                source="core2"
                target="support1"
                parent="1"
                value="Consulta confianza de dispositivo"
                style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4"
                edge="1"
                source="core2"
                target="support2"
                parent="1"
                value="Consulta comportamiento histórico"
                style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5"
                edge="1"
                source="core2"
                target="support3"
                parent="1"
                value="Activa mitigaciones"
                style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AUTH -->

        <mxCell id="e6"
                edge="1"
                source="core3"
                target="support4"
                parent="1"
                value="Ejecuta factores"
                style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AUDITORIA -->

        <mxCell id="e7"
                edge="1"
                source="core1"
                target="generic"
                parent="1"
                value="Eventos"
                style="dashed=1;endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8"
                edge="1"
                source="core2"
                target="generic"
                parent="1"
                value="Eventos"
                style="dashed=1;endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9"
                edge="1"
                source="core3"
                target="generic"
                parent="1"
                value="Eventos"
                style="dashed=1;endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- EVENT DRIVEN -->

        <mxCell id="e10"
                edge="1"
                source="core1"
                target="platform"
                parent="1"
                style="dashed=1;endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e11"
                edge="1"
                source="core2"
                target="platform"
                parent="1"
                style="dashed=1;endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e12"
                edge="1"
                source="core3"
                target="platform"
                parent="1"
                style="dashed=1;endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e13"
                edge="1"
                source="support1"
                target="platform"
                parent="1"
                style="dashed=1;endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e14"
                edge="1"
                source="support2"
                target="platform"
                parent="1"
                style="dashed=1;endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e15"
                edge="1"
                source="support3"
                target="platform"
                parent="1"
                style="dashed=1;endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e16"
                edge="1"
                source="support4"
                target="platform"
                parent="1"
                style="dashed=1;endArrow=block;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>