                parent="1">
          <mxGeometry x="850" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- ========================= -->
        <!-- DECISION TRANSACCIONAL -->
        <!-- ========================= -->

        <mxCell id="ctx1"
