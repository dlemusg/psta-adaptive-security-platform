<mxfile host="app.diagrams.net">
  <diagram name="DDD Domain Model">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="2200" pageHeight="1600">

      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITULO -->

        <mxCell id="title"
