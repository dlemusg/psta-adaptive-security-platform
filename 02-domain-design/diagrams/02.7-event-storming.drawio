<mxfile host="app.diagrams.net">
  <diagram name="Event Storming">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1"
                  page="1" pageScale="1" pageWidth="3400" pageHeight="1800">

      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===================================================== -->
        <!-- TITLE -->
        <!-- ===================================================== -->

        <mxCell id="title"
                value="Event Storming - Plataforma de Seguridad Transaccional Adaptativa (PSTA)"
                style="text;html=1;fontSize=24;fontStyle=1;strokeColor=none;fillColor=none;"
                vertex="1"
                parent="1">
          <mxGeometry x="900" y="20" width="1000" height="40" as="geometry"/>
        </mxCell>

        <!-- ===================================================== -->
        <!-- ESCENARIO 1 -->
        <!-- ===================================================== -->

        <mxCell id="scenario1"
                value="Escenario 1 - Detección de Fraude por Velocidad"
                style="text;html=1;fontSize=18;fontStyle=1;"
                vertex="1"
                parent="1">
          <mxGeometry x="40" y="100" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- Actor -->

        <mxCell id="actor1"
                value="Cliente"
                style="shape=umlActor;"
                vertex="1"
                parent="1">
          <mxGeometry x="40" y="180" width="60" height="100" as="geometry"/>
        </mxCell>

        <!-- Command -->

        <mxCell id="cmd1"
                value="Command&#10;Iniciar Transferencia"
                style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
